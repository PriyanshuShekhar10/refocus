# ===========================================
# MongoDB Configuration
# ===========================================
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=refocus
# ===========================================
# NextAuth Configuration
# ===========================================
NEXTAUTH_SECRET=3q8poO5+ZKjftD5IUIK3OTh627mq9HM3jjQGNJ1vX0gw
NEXTAUTH_URL=http://localhost:3000

# ===========================================
# Redis Configuration (Optional - for horizontal scaling)
# ===========================================
# Required for production deployments with multiple instances.
# The in-memory event bus will be used if not configured.
#
# For Upstash Redis:
#   Get your URL from https://console.upstash.com/
#   Format: redis://default:<password>@<host>:<port>
#
# For local Redis:
#   REDIS_URL=redis://localhost:6379
#
# REDIS_URL=redis://default:your-password@your-host.upstash.io:6379

# ===========================================
# Upstash Rate Limiting (Optional - for rate limiting)
# ===========================================
# Required for production to prevent API abuse.
# Get these from https://console.upstash.com/
#
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here