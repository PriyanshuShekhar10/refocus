# Resend (welcome + verification emails on sign-up)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Refocus <hello@refocus.co.in>

# Public site URL (used in verification links)
NEXT_PUBLIC_SITE_URL=https://refocus.co.in

# Public HTTPS origin for email images (Gmail/Outlook block data: URIs — must be production URL)
EMAIL_ASSET_BASE_URL=https://refocus.co.in

# Vercel Cron auth (Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=generate-a-long-random-string

# 1h/10m session reminders need a scheduler every 5 min (Vercel Pro cron, or external
# service calling GET /api/cron/session-reminders with the CRON_SECRET bearer token).
